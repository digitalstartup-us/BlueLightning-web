# Resend API Key — get from resend.com/api-keys
# Add this to Vercel: Settings > Environment Variables > RESEND_API_KEY
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# OpenAI API Key — get from platform.openai.com/api-keys
# Add this to Vercel: Settings > Environment Variables > OPENAI_API_KEY
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# Gmail SMTP — used to send ALL emails (leads + confirmations)
# Works on any hosting without domain verification
# Step 1: Enable 2-Step Verification on Google Account
# Step 2: Google Account → Security → App Passwords → Create → copy 16-char password
# Step 3: Add both vars to Vercel: Settings > Environment Variables
GMAIL_USER=caballeromauricio766@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Google Tag Manager — get this from tagmanager.google.com
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Search Console verification — get this from search.google.com/search-console
NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxx

# Production site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://bluelightning.com

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# firebase
.firebase/

# typescript
*.tsbuildinfo
next-env.d.ts

# large media files — ignore only files over 100MB
/public/video/Blue Lightning 4K.mp4
/public/video/Mauricio - Outdoor Living Designer (4K High Quality).mp4
/public/video/BLUE LIGHTNING Final video copy.mp4

# to_review staging folder — not for production
/public/to_review/
